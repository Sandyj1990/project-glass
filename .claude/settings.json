        "*.githubusercontent.com",
        "registry.npmjs.org",
        "*.npmjs.org",
        "vercel.com",
        "*.vercel.app",
        "fonts.googleapis.com",
        "fonts.gstatic.com",
        "cdn.tailwindcss.com",
        "storage.googleapis.com"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "~/.agent-browser"
      ]
    }
  },
  "enabledPlugins": {
    "ui-ux-pro-max@ui-ux-pro-max-skill": true
  }
}
