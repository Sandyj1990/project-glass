      "Bash(agent-browser *)",
      "Bash(curl -s *)",
      "Bash(curl -sI *)",
      "Bash(curl -sf *)",
      "Bash(curl -sSL *)",
      "Bash(gsutil ls *)",
      "Bash(pdftotext *)"
